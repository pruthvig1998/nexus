# ─────────────────────────────────────────────────────────────────────────────
# NEXUS v3 — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Alpaca Markets (default broker — free paper trading) ─────────────────────
# Sign up at https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true

# ── Interactive Brokers (requires TWS or IB Gateway running locally) ─────────
# Install: pip install "nexus-trader[ibkr]"
# Docs: https://github.com/erdewit/ib_insync
# TWS paper port: 7497 | TWS live: 7496 | IB Gateway paper: 4002 | live: 4001
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1

# ── Moomoo / Futu (requires OpenD gateway running locally) ───────────────────
# Install: pip install "nexus-trader[moomoo]"
# Download OpenD: https://www.futunn.com/download/OpenAPI
# MOOMOO_HOST=127.0.0.1
# MOOMOO_PORT=11111
# MOOMOO_TRADE_ENV=SIMULATE    # SIMULATE or REAL

# ── Webull (unofficial API — paper trading recommended) ──────────────────────
# Install: pip install "nexus-trader[webull]"
# ⚠️  Unofficial reverse-engineered library — may break with Webull updates
# WEBULL_EMAIL=your@email.com
# WEBULL_PASSWORD=your_password
# WEBULL_TRADING_PIN=123456    # 6-digit PIN from Webull app
# WEBULL_DEVICE_ID=            # auto-filled after first login — paste here to skip 2FA
# WEBULL_PAPER=true

# ── Anthropic (optional — enables AI fundamental strategy) ───────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Discord Bot (optional — monitors channels for trading signals) ────────────
# Setup guide:
#   1. discord.com/developers/applications → New Application → Bot tab → Add Bot
#   2. Copy the Token below → DISCORD_BOT_TOKEN
#   3. Bot → Privileged Gateway Intents → enable "Message Content Intent"
#   4. OAuth2 → URL Generator → Scopes: bot → Permissions: Read Messages,
#      Read Message History → open the generated URL to invite bot to your servers
#   5. Discord Settings → Advanced → enable Developer Mode
#      Right-click any channel → Copy ID → paste in DISCORD_CHANNEL_IDS
# Install: pip install "nexus-trader[discord]"
# DISCORD_BOT_TOKEN=your_bot_token_here
# DISCORD_CHANNEL_IDS=123456789,987654321   # empty = monitor all channels in all servers

# ── Twitter/Nitter RSS (optional — monitors tweets for trading signals) ────
# No API key needed — uses public Nitter RSS instances
# TWITTER_ACCOUNTS=DeItaone,unusual_whales,zerohedge,FirstSquawk,LiveSquawk
# TWITTER_POLL_INTERVAL=20
# NITTER_INSTANCES=nitter.poast.org,nitter.privacydev.net,nitter.cz,nitter.net,nitter.1d4.us,nitter.kavin.rocks,nitter.unixfox.eu,nitter.domain.glass

# ── Telegram Alerts (optional — sends trade notifications to your phone) ──
# Setup guide:
#   1. Message @BotFather on Telegram → /newbot → follow prompts
#   2. Copy the bot token below → TELEGRAM_BOT_TOKEN
#   3. Message your bot, then visit:
#      https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#      to find your chat_id
#   4. Set TELEGRAM_ENABLED=true
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
# TELEGRAM_ENABLED=false
